{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "bundler",
    "noEmit": true,
    "allowJs": true,
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "npm:*": ["node_modules/*"]
    }
  },
  "include": [
    "supabase/functions/**/*.ts",
    "supabase/functions/deno-types.d.ts"
  ]
}
