# Touring Diary — Environment variables template
# Copia questo file in `.env` e popola i valori reali.
# NON committare mai il file `.env` con valori reali.

# --- Supabase (client, esposte al browser tramite prefisso VITE_) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Supabase (solo server: NON deve avere prefisso VITE_, mai esposta al client) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- API ---
# Lasciare vuoto per usare URL relativi same-origin (proxy Vite in dev, stesso server in prod).
# Valorizzare solo se l'API è servita da un'origine differente (es. https://api.<dominio>).
VITE_API_URL=

# --- Feature flag opzionali ---
# Abilita le funzionalità AI lato client (lasciare vuoto per disattivarle).
VITE_USE_AI=

# --- Server (opzionale) ---
# Porta del server Express; default 3000 se non impostata.
PORT=
